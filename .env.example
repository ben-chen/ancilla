# Project-local AWS configuration for ancilla development.
# Load these into your shell or copy them into `.env.local`.

AWS_CONFIG_FILE=$PWD/.aws/config
AWS_SHARED_CREDENTIALS_FILE=$PWD/.aws/credentials
AWS_PROFILE=ancilla-dev
AWS_REGION=us-west-2
AWS_DEFAULT_REGION=us-west-2

# Ancilla application config
ANCILLA_APP_ENV=development
ANCILLA_DATA_FILE=.ancilla/state.json
ANCILLA_ACCEPT_CLIENT_EMBEDDINGS=true
ANCILLA_ACCEPT_CLIENT_TRANSCRIPTS=true
ANCILLA_LOCAL_EMBED_MODEL=perplexity-ai/pplx-embed-v1-0.6b
ANCILLA_LOCAL_CONTEXT_EMBED_MODEL=perplexity-ai/pplx-embed-context-v1-0.6b
ANCILLA_LOCAL_EMBED_DEVICE=auto
BEDROCK_CHAT_MODEL_ID=
BEDROCK_CHAT_MAX_TOKENS=800
BEDROCK_CHAT_TEMPERATURE=0.2
DATABASE_URL=
