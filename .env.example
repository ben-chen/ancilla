# Project-local AWS configuration for ancilla development and deploy tooling.

AWS_CONFIG_FILE=$PWD/.aws/config
AWS_SHARED_CREDENTIALS_FILE=$PWD/.aws/credentials
AWS_PROFILE=ancilla-dev
AWS_REGION=us-west-2
AWS_DEFAULT_REGION=us-west-2

# ancilla-server config
ANCILLA_SERVER_APP_ENV=development
ANCILLA_SERVER_DATA_FILE=.ancilla/state.json
ANCILLA_SERVER_ACCEPT_CLIENT_EMBEDDINGS=true
ANCILLA_SERVER_ACCEPT_CLIENT_TRANSCRIPTS=true
ANCILLA_SERVER_LOCAL_EMBED_MODEL=perplexity-ai/pplx-embed-v1-0.6b
ANCILLA_SERVER_LOCAL_CONTEXT_EMBED_MODEL=perplexity-ai/pplx-embed-context-v1-0.6b
ANCILLA_SERVER_LOCAL_EMBED_DEVICE=auto
ANCILLA_SERVER_BEDROCK_CHAT_MODEL_ID=
ANCILLA_SERVER_BEDROCK_CHAT_MAX_TOKENS=800
ANCILLA_SERVER_BEDROCK_CHAT_TEMPERATURE=0.2

# Standard server fallbacks still accepted by ancilla-server and used in deploys.
DATABASE_URL=
BEDROCK_CHAT_MODEL_ID=

# ancilla-client config
ANCILLA_CLIENT_BASE_URL=http://127.0.0.1:3000
