aws_region              = "us-west-2"
aws_profile             = "ancilla-dev"
name_prefix             = "ancilla"
app_env                 = "production"
create_network          = true
availability_zones      = ["us-west-2a", "us-west-2b"]
vpc_cidr                = "10.42.0.0/16"
public_subnet_cidrs     = ["10.42.0.0/24", "10.42.1.0/24"]
private_app_subnet_cidrs = ["10.42.10.0/24", "10.42.11.0/24"] # reserved for future private services
private_db_subnet_cidrs  = ["10.42.20.0/24", "10.42.21.0/24"]
domain_name              = "ancillabot.com"
enable_https_listener    = false
basic_auth_enabled       = false
basic_auth_username      = "ancilla"
bedrock_chat_model_id    = "moonshotai.kimi-k2.5"
bedrock_gate_model_id    = "moonshotai.kimi-k2.5"
bedrock_chat_models = [
  {
    label       = "Kimi K2.5"
    model_id    = "moonshotai.kimi-k2.5"
    description = "Moonshot general-purpose model"
  },
]
container_image_tag      = "latest"
embedder_enabled         = true
embedder_image_tag       = "latest"
embedder_accelerator     = "cpu"
embedder_instance_type   = "t3.large"
embedder_port            = 4000
embedder_device          = "cpu"
embedder_timeout_seconds = 120
desired_count            = 1
task_cpu                 = 256
task_memory              = 1024
db_engine_version        = "15.8"
db_instance_class        = "db.t4g.micro"
db_allocated_storage_gb  = 20
db_max_allocated_storage_gb = 100
